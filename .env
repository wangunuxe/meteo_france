# 数据库密码等配置# Airflow 元数据库
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# 业务数据库
WEATHER_DB_HOST=weather-db
WEATHER_DB_NAME=weather
